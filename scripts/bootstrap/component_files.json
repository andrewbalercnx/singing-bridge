    },
    "council": {
      "files": [
        "scripts/council-review.py",
        "scripts/council-config.json",
        "scripts/council-check.sh",
        "scripts/process-test.py",
        ".claude/skills/council-plan.md",
        ".claude/skills/council-code.md"
      ]
    },
    "skills": {
      "files": [
        ".claude/skills/sprint-start.md",
        ".claude/skills/sprint-complete.md",
        ".claude/skills/check-headers.md"
      ]
    },
    "guardrails": {
      "files": ["scripts/hooks/guardrails.py"]
    },
    "compaction": {
      "files": []
    },
    "findings_archive": {
      "files": []
    },
    "digest": {
      "files": ["scripts/findings-digest.py"]
    },
    "metrics_digest": {
      "files": ["scripts/council-metrics-digest.py"]
    }
  }
}
