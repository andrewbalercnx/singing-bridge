# Caches
.mypy_cache/
.ruff_cache/

# Claude Code (keep .claude/settings.json and template-owned skill files tracked)
.claude/codebase.db
.claude/codebase.db-*
.claude/settings.local.json
.claude/skills/*
!.claude/skills/*.md
.claude/worktrees/

# Generated digest output + per-sprint findings archive (runtime state)
Documentation/FINDINGS_DIGEST.md
Documentation/COUNCIL_METRICS_DIGEST.md
Documentation/TOKEN_AUDIT.md
Documentation/findings-archive/

# Pair programming working files (transient, per-sprint)
PLAN_Sprint*.md
REVIEW_Sprint*.md
FINDINGS_Sprint*.md
# ...except archived plans, which are deliberately tracked as history
!Documentation/archive/PLAN_Sprint*.md
# ...and except test fixtures for findings-digest (Sprint 5 CI fix — the
# fixtures were silently swallowed by the glob above, which meant
# `pytest tests/test_digest.py` passed locally but failed on a fresh
# clone with no fixture files present).
!tests/fixtures/findings/FINDINGS_Sprint*.md
.review-round-*
.sprint-base-commit-*

# Generated context packs (transient)
codex/context/

# Council review working files (transient) — ignore contents but not the dir
# so the metrics negation below can take effect (git can't un-ignore inside
# a directory-level ignore rule)
council/*
# ...except metrics JSONL — these are the primary audit trail for council efficiency
!council/metrics_Sprint*.jsonl

# Logs
*_debug.log
*.log

# OS
.DS_Store
Thumbs.db
~$*

# Secrets
**/dev-keys.txt
**/api_keys.local.json
*.pem
*.key

# Current sprint marker (per-machine, transient)
.current-sprint
.wrangler/

# E2E test runtime artifacts
.e2e-auth-state.json
.e2e-slug.txt
.playwright-mcp/
data/dev-mail/
test-results/
