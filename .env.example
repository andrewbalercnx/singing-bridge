# .env.example — copy to .env and fill in secrets before running docker-compose
# Last updated: Sprint 12A (2026-04-21)

# Server
SB_ENV=dev
SB_BASE_URL=http://localhost:8080

# Sidecar shared secret (must be ≥ 32 bytes in prod)
SIDECAR_SECRET=dev-sidecar-secret-change-me-in-prod

# Sidecar host allowlist — required when SIDECAR_URL points at a non-loopback host.
# Value is an exact hostname (parsed via url::Url, no wildcards, comma-separated for
# multiple hosts). Omit or leave empty to allow only loopback (127.0.0.1, ::1, localhost).
# SIDECAR_HOST_ALLOWLIST=sidecar
